<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="bng-team">
        <comment>Create bng schema</comment>
        <sql>CREATE SCHEMA IF NOT EXISTS bng;</sql>
        <rollback>DROP SCHEMA IF EXISTS bng CASCADE;</rollback>
    </changeSet>

    <changeSet id="2" author="bng-team">
        <comment>Create projects table in bng schema</comment>
        <createTable schemaName="bng" tableName="projects">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="bng_project_version" type="integer" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
